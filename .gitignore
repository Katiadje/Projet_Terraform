# Local .terraform directories
**/.terraform/*

# .tfstate files (state files for Terraform)
*.tfstate
*.tfstate.*

# Crash log files generated by Terraform
crash.log
crash.*.log

# Exclude .tfvars files, which may contain sensitive data (passwords, API keys, etc.)
*.tfvars
*.tfvars.json

# Ignore override files that are usually used for local development
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore Terraform CLI configuration files
.terraformrc
terraform.rc

# Ignore lock files
.terraform.lock.hcl

# Ignore any .env files that might contain secrets (local environment variables)
.env

# Ignore any other local development files
*.log
.DS_Store
